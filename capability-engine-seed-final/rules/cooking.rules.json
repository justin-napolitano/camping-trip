{
  "id": "cooking-v1",
  "priority": 30,
  "rules": [
    {
      "description": "Block if fuel insufficient",
      "id": "fuel_margin_rule",
      "if": {
        "lt": [
          "available_fuel_g",
          {
            "mul": [
              "required_fuel_g",
              1.3
            ]
          }
        ]
      },
      "priority": 100,
      "then": {
        "action": "block",
        "reason": "fuel_insufficient"
      }
    },
    {
      "description": "Canister stoves need backup at <=0C",
      "id": "canister_cold_rule",
      "if": {
        "and": [
          {
            "lte": [
              "trip.expected_low_c",
              0
            ]
          },
          {
            "eq": [
              "primary_stove.fuel_type",
              "canister"
            ]
          }
        ]
      },
      "priority": 200,
      "then": {
        "action": "require",
        "reason": "canister_unreliable_in_cold",
        "require": [
          "backup_stove_non_canister",
          "stove_cold_test"
        ]
      }
    }
  ]
}