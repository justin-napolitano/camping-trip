{
  "$id": "https://example.org/schemas/Trip.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "end_date": {
      "format": "date",
      "type": "string"
    },
    "expected_high_c": {
      "type": "number"
    },
    "expected_low_c": {
      "type": "number"
    },
    "group_size": {
      "minimum": 1,
      "type": "integer"
    },
    "location": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "precipitation": {
      "enum": [
        "none",
        "light",
        "moderate",
        "heavy",
        "snow",
        "mixed"
      ],
      "type": "string"
    },
    "remoteness": {
      "enum": [
        "near",
        "semi_remote",
        "remote"
      ],
      "type": "string"
    },
    "required_levels_override": {
      "type": "object"
    },
    "start_date": {
      "format": "date",
      "type": "string"
    },
    "static_exposure": {
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "type": "string"
    },
    "style": {
      "enum": [
        "backpack",
        "car",
        "alpine-lite",
        "alpine",
        "expedition"
      ],
      "type": "string"
    },
    "trip_id": {
      "type": "string"
    },
    "wind_mph": {
      "minimum": 0,
      "type": "number"
    }
  },
  "required": [
    "trip_id",
    "start_date",
    "end_date",
    "style",
    "expected_low_c",
    "expected_high_c"
  ],
  "title": "Trip",
  "type": "object"
}