{
  "$id": "https://camping-trip.local/schemas/GearListResponse.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GearListResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["items", "page", "limit", "total"],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "slug", "name", "composite_score", "confidence_score", "explainability"],
        "properties": {
          "id": { "type": "string" },
          "slug": { "type": "string" },
          "name": { "type": "string" },
          "composite_score": { "type": "number" },
          "confidence_score": { "type": "number" },
          "explainability": {
            "type": "object",
            "additionalProperties": false,
            "required": ["factors", "tie_break_path"],
            "properties": {
              "factors": { "type": "array", "items": { "type": "string" } },
              "tie_break_path": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "page": { "type": "integer", "minimum": 1 },
    "limit": { "type": "integer", "minimum": 1, "maximum": 100 },
    "total": { "type": "integer", "minimum": 0 }
  }
}
